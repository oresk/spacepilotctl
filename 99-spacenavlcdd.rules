# Start spacenavlcdd when a SpacePilot HP is plugged in.
# Install to /etc/udev/rules.d/99-spacenavlcdd.rules

ACTION=="add", SUBSYSTEM=="usb", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c625", TAG+="systemd", ENV{SYSTEMD_USER_WANTS}="spacenavlcdd.service"
ACTION=="remove", SUBSYSTEM=="usb", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c625", RUN+="/usr/bin/systemctl --user stop spacenavlcdd.service"
